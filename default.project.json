{
  "name": "genrojotree",
  "emitLegacyScripts": false,
  
  "tree": {
    "$className": "DataModel",
    
    "ReplicatedStorage": {
      "Client": {
        "$path": "src/startup/Client.client.luau"
      }
      
      "Shared": {
        "$className": "Folder",
        "Services": {
          "$className": "Folder",
        },
        "Classes": {
          "$className": "Folder"
        },
        "Modules": {
          "$className": "Folder"
        }
      },
      "Packages": {
        "$path": "Packages"
      },
      "UI": {
        "$path": "src/ui"
      }
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/startup/Server.server.luau"
      },
      "Services": {
        "$className": "Folder"
      },
      "Classes": {
        "$className": "Folder"
      },
      "Modules": {
        "$className": "Folder"
      }
    }
  }
}
