{
  "name": "genrojotree",
  "emitLegacyScripts": false,
  
  "tree": {
    "$className": "DataModel",
    
    "ReplicatedStorage": {
      "Client": {
        "$path": "src/startup/Client.client.luau"
      }
      
      "Shared": {
        "$className": "Folder",
        "Services": {
          "$className": "Folder",
          "ExampleService": {
            "$className": "Folder",
            "ExampleServiceClient": {
              "$path": "src/services/ExampleService/Client.luau"
            },
            "ExampleServiceUtils": {
              "$path": "src/services/ExampleService/Utils.luau"
            }
          }
        },
        "Classes": {
          "$className": "Folder"
        },
        "Modules": {
          "$className": "Folder"
        }
      },
      "Packages": {
        "$path": "Packages"
      },
      "UI": {
        "$path": "src/ui"
      }
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/startup/Server.server.luau"
      },
      "Services": {
        "$className": "Folder",
        "ExampleService": {
          "$className": "Folder",
          "ExampleServiceServer": {
            "$path": "src/services/ExampleService/Server.luau"
          }
        }
      },
      "Classes": {
        "$className": "Folder"
      },
      "Modules": {
        "$className": "Folder"
      }
    }
  }
}
